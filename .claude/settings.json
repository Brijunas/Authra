{
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true
  },
  "enableAllProjectMcpServers": true,
  "autoMemoryEnabled": true,
  "permissions": {
    "allow": [
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet format:*)",
      "Bash(dotnet list:*)",
      "Bash(wc:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./appsettings.Development.json)",
      "Read(./appsettings.*.local.json)",
      "Bash(rm -rf:*)"
    ]
  }
}
